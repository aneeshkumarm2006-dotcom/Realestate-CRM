# ---------------------------------------------------------------------------
# Server environment template. Copy to `server/.env` and fill in real values.
# `.env` is gitignored; this example is committed. Never commit real secrets.
# ---------------------------------------------------------------------------

# --- Core ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?appName=<app>

# --- JWT ---
JWT_SECRET=                       # 64-char hex; e.g. openssl rand -hex 32
JWT_EXPIRES_IN=7d

# --- Google OAuth (app login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# --- Cloudinary (uploads; F8 email attachments land under macan/emails/) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Resend (system / fallback email — kept by F8 as the no-mailbox fallback) ---
RESEND_API_KEY=
EMAIL_FROM=automations@example.com

# --- Frontend URL (redirects after OAuth) ---
CLIENT_URL=http://localhost:5173

# ===========================================================================
# Phase 3 — Communication Integration (F7-F11).
# Provision per feature before that feature's QA; also add the real values to
# the deploy secret store. Values below are placeholders.
# ===========================================================================

# --- F7 Webhooks: shared public base URL for inbound + provider callbacks ---
WEBHOOK_PUBLIC_BASE_URL=http://localhost:5000
# rateLimit.js is an in-memory single-process token bucket (pre-flight decision).
# Optional replica hint — it warns at startup if this indicates > 2 instances:
# SERVER_REPLICAS=1

# --- F7 Sentry: error tracking (confirmed in scope for Phase 3) ---
# Leave unset locally; Sentry init is a no-op without a DSN.
SENTRY_DSN=

# --- F8 Email: token encryption (AES-256-GCM), 32-byte hex key ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_TOKEN_ENCRYPTION_KEY=
# Set during key rotation only (re-encrypt-on-read fallback); drop once migrated.
EMAIL_TOKEN_ENCRYPTION_KEY_PREVIOUS=

# --- F8 Email: provider OAuth (Gmail + Microsoft 365) ---
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
# Optional — Gmail push (Pub/Sub) inbound; IMAP/heartbeat fallback if unset.
GMAIL_PUBSUB_TOPIC=

# --- F10/F11 Twilio (SMS + WhatsApp) ---
# Per-workspace Account SID / Auth Token live in SmsConfig / WhatsAppConfig
# (DB, encrypted with EMAIL_TOKEN_ENCRYPTION_KEY) — NOT env vars.
# Public callback base URL (defaults to WEBHOOK_PUBLIC_BASE_URL if unset). MUST
# exactly match the inbound/status URLs configured in Twilio (signature is
# computed over the full URL):
TWILIO_WEBHOOK_BASE_URL=http://localhost:5000
# Dev-only escape hatch: set to "true" to skip Twilio X-Twilio-Signature
# validation on the public SMS/WhatsApp callbacks (never enable in production).
# TWILIO_SKIP_SIGNATURE_VALIDATION=false

# ===========================================================================
# Phase 4 — Visualization & Insights (F12-F16).
# Provision per feature before that feature's QA; also add the real values to
# the deploy secret store. Values below are placeholders.
# ===========================================================================

# --- F13 Forms: Cloudflare Turnstile CAPTCHA (optional) ---
# Anti-spam on public forms. formSubmissionService verifies cf-turnstile-response
# when captchaEnabled; if these are unset, captcha verification is skipped cleanly.
# The public form link (/f/:slug) reuses WEBHOOK_PUBLIC_BASE_URL above for its URL.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# --- F14 AI Lead Scoring & Auto-Response: Anthropic API ---
# Required only for the LLM method (the deterministic `rules` method needs no key).
ANTHROPIC_API_KEY=
# Model overrides — aiClient.js defaults to claude-sonnet-4-6 when unset.
AI_SCORING_MODEL=claude-sonnet-4-6
AI_REPLY_MODEL=claude-sonnet-4-6
